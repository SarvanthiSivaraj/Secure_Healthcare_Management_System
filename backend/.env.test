NODE_ENV=test

# Database - Test DB runs on port 5433 (separate from dev)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=healthcare_test_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=testsecret1234567890123456789012
JWT_REFRESH_SECRET=testrefreshsecret1234567890123456
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Security - must be exactly 64 hex chars (32 bytes for AES-256)
ENCRYPTION_KEY=74657374656e6372797074696f6e6b657931323334353637383930313233343530

# Lower bcrypt rounds for fast tests
BCRYPT_ROUNDS=4

CORS_ORIGIN=*
API_VERSION=v1

# OTP - longer expiry so tests don't race
OTP_EXPIRY_MINUTES=60
OTP_MAX_ATTEMPTS=10
OTP_LENGTH=6

# Rate limiting - very generous for tests
RATE_LIMIT_MAX_REQUESTS=10000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=100
OTP_RATE_LIMIT_MAX_ATTEMPTS=100

# Email - disabled in tests
EMAIL_HOST=
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@test.com

# WebAuthn
WEBAUTHN_RP_NAME=TestHealth
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
