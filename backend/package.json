{
  "name": "healthcare-backend",
  "version": "1.0.0",
  "description": "Secure Healthcare Information & Patient Management System - Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/database/migrate.js",
    "db:seed": "node src/database/seed.js",
    "db:setup:all": "node src/database/setup_full_db.js",
    "test": "vitest run --coverage",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest"
  },
  "keywords": [
    "healthcare",
    "HIPAA",
    "GDPR",
    "medical-records",
    "patient-management"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@simplewebauthn/server": "^13.2.2",
    "axios": "^1.13.4",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "vitest": "^1.6.0"
  }
